---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ImageCards from '~/components/widgets/ImageCards.astro';

const metadata = {
  title: 'Despre noi - Școala Teofil',
  description: 'Descoperiți toate aspectele Școlii Teofil - istoric, rezultate, echipa, noutăți și multe altele.',
};
---

<Layout metadata={metadata}>
  <HeroText title="Despre noi" subtitle="Descoperiți povestea, echipa și valorile Școlii Teofil." />

  <ImageCards
    title=""
    subtitle=""
    columns={3}
    cards={[
      {
        title: 'Scurt istoric',
        description: 'Descoperiți povestea noastră, valorile și evoluția Școlii Teofil de-a lungul anilor.',
        image: {
          src: '~/assets/images/cards/scurt-istoric.jpg',
          alt: 'Scurt istoric',
        },
        callToAction: {
          text: 'Citiți mai mult',
          href: '/despre-noi/scurt-istoric',
        },
      },
      {
        title: 'Echipa noastră',
        description:
          'Cunoașteți echipa dedicată de profesori și pedagogi care lucrează cu pasiune pentru educația copiilor.',
        image: {
          src: '~/assets/images/cards/echipa-noastra.jpg',
          alt: 'Echipa noastră',
        },
        callToAction: {
          text: 'Cunoașteți echipa',
          href: '/despre-noi/echipa-noastra',
        },
      },
      {
        title: 'Rezultate',
        description: 'Realizările și succesele elevilor noștri în diverse competiții și activități educaționale.',
        image: {
          src: '~/assets/images/cards/rezultate.jpg',
          alt: 'Rezultate',
        },
        callToAction: {
          text: 'Vedeți rezultatele',
          href: '/despre-noi/rezultate',
        },
      },
      {
        title: 'Contact',
        description: 'Contactați-ne pentru mai multe informații sau pentru a programa o vizită.',
        image: {
          src: '~/assets/images/cards/contact.jpg',
          alt: 'Contact',
        },
        callToAction: {
          text: 'Contactați-ne',
          href: '/contact',
        },
      },
    ]}
  />
</Layout>
