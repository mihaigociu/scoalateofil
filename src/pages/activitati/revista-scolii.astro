---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'Revista școlii - Școala Teofil',
  description: 'Publicația Școlii Teofil cu articole scrise de elevi, profesori și părinți.',
};

const numere = [
  {
    numar: 1,
    an: 2025,
    titlu: 'Foileton Școala Teofil – Nr. 1, 2025',
    descriere: 'Primul număr al revistei Școlii Teofil, cu articole, povești și realizări ale comunității noastre.',
    pdf: '/reviste/foileton-nr-1-2025.pdf',
  },
];
---

<Layout metadata={metadata}>
  <HeroText title="Revista școlii" subtitle="Vocea comunității noastre" />

  <!-- Numerele revistei -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="space-y-12">
      {
        numere.map((item) => (
          <div class="rounded-xl shadow-lg overflow-hidden border border-gray-200 dark:border-gray-700">
            <div class="p-6 bg-white dark:bg-slate-900">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4">
                <div>
                  <h3 class="text-xl font-bold">{item.titlu}</h3>
                  <p class="text-muted mt-1">{item.descriere}</p>
                </div>
                <a
                  href={item.pdf}
                  download
                  class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-primary text-white font-semibold hover:bg-primary/90 transition-colors whitespace-nowrap"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                      <polyline points="7 10 12 15 17 10" />
                      <line x1="12" y1="15" x2="12" y2="3" />
                    </>
                  </svg>
                  Descarcă PDF
                </a>
              </div>
              <iframe
                src={item.pdf}
                class="w-full rounded-lg border border-gray-200 dark:border-gray-700"
                style="height: 600px;"
                title={item.titlu}
              />
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
